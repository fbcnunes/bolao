generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  MASTER
  PARTICIPANTE
}

enum BolaoStatus {
  PENDENTE
  ATIVO
  RECUSADO
}

enum MemberRole {
  ADMIN
  PARTICIPANTE
}

enum UserStatus {
  PENDENTE
  ATIVO
  RECUSADO
  REMOVIDO
}

enum MemberStatus {
  PENDENTE
  ATIVO
  RECUSADO
  REMOVIDO
}

enum MatchPhase {
  GRUPOS
  PLAYOFFS
  OITAVAS
  QUARTAS
  SEMI
  FINAL
}

enum MatchStatus {
  AGENDADO
  AO_VIVO
  ENCERRADO
}

enum PredictionResult {
  CASA
  EMPATE
  FORA
}

model User {
  id            String        @id @default(cuid())
  name          String
  email         String        @unique
  passwordHash  String
  role          Role          @default(PARTICIPANTE)
  status        UserStatus    @default(PENDENTE)
  createdAt     DateTime      @default(now())
  predictions   Prediction[]
  scores        Score[]
  boloesCreated Bolao[]
  bolaoMembers  BolaoMember[]
}

model Bolao {
  id              String        @id @default(cuid())
  nome            String
  inviteCode      String        @unique @default(cuid())
  status          BolaoStatus   @default(PENDENTE)
  premiacaoRegra  String?       @db.Text
  createdById     String
  createdBy       User          @relation(fields: [createdById], references: [id])
  members         BolaoMember[]
  predictions     Prediction[]
  scores          Score[]
  createdAt       DateTime      @default(now())
}

model BolaoMember {
  bolaoId      String
  bolao        Bolao        @relation(fields: [bolaoId], references: [id])
  userId       String
  user         User         @relation(fields: [userId], references: [id])
  role         MemberRole   @default(PARTICIPANTE)
  status       MemberStatus @default(PENDENTE)
  championPick String?

  @@id([bolaoId, userId])
}

model Match {
  id          String            @id @default(cuid())
  apiId       Int               @unique
  phase       MatchPhase
  round       Int
  group       String            @default("")
  homeTeam    String
  awayTeam    String
  dateTime    DateTime
  result      PredictionResult?
  status      MatchStatus       @default(AGENDADO)
  odds        Odd[]
  predictions Prediction[]
}

model Odd {
  id          String           @id @default(cuid())
  matchId     String
  match       Match            @relation(fields: [matchId], references: [id])
  oddHome     Float
  oddDraw     Float
  oddAway     Float
  favorite    PredictionResult
  capturedAt  DateTime         @default(now())
  predictions Prediction[]
}

model Prediction {
  id           String           @id @default(cuid())
  bolaoId      String
  bolao        Bolao            @relation(fields: [bolaoId], references: [id])
  userId       String
  user         User             @relation(fields: [userId], references: [id])
  matchId      String
  match        Match            @relation(fields: [matchId], references: [id])
  prediction   PredictionResult
  oddId        String?
  odd          Odd?             @relation(fields: [oddId], references: [id])
  oddTimestamp DateTime?
  correct      Boolean?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@unique([bolaoId, userId, matchId])
}

model Round {
  id              String     @id @default(cuid())
  phase           MatchPhase
  number          Int
  bonusCalculated Boolean    @default(false)
  scores          Score[]
}

model Score {
  id                String @id @default(cuid())
  bolaoId           String
  bolao             Bolao  @relation(fields: [bolaoId], references: [id])
  userId            String
  user              User   @relation(fields: [userId], references: [id])
  roundId           String
  round             Round  @relation(fields: [roundId], references: [id])
  roundPoints       Float  @default(0)
  bonus             Float  @default(0)
  accumulatedPoints Float  @default(0)

  @@unique([bolaoId, userId, roundId])
}
